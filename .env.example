NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.2
LLM_NUM_CTX=8192

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_BATCH_SIZE=16

WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_MAX_PARAGRAPHS=18
PASSAGE_CHUNK_SIZE=1400
PASSAGE_PARAGRAPH_OVERLAP=1
KG_BUILDER_MAX_PARAGRAPHS=40
KG_BUILDER_CHUNK_SIZE=1800
KG_BUILDER_CHUNK_OVERLAP=150
KG_BUILDER_SCHEMA_MODE=GUIDED
