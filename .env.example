NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

LLM_PROVIDER=ollama
LLM_MODEL=gemma4:e2b
KG_BUILDER_LLM_MODEL=qwen2.5:3b
CLAIM_EXTRACTION_LLM_MODEL=qwen2.5:3b
COMMUNITY_REPORT_LLM_MODEL=gemma4:e2b
ROUTER_LLM_MODEL=gemma4:e2b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.1
LLM_NUM_CTX=4096

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=mps
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_BATCH_SIZE=16

WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_MAX_PARAGRAPHS=18
PASSAGE_CHUNK_SIZE=1400
PASSAGE_PARAGRAPH_OVERLAP=1
KG_BUILDER_MAX_PARAGRAPHS=20
KG_BUILDER_CHUNK_SIZE=1200
KG_BUILDER_CHUNK_OVERLAP=100
KG_BUILDER_SCHEMA_MODE=GUIDED

CACHE_DIR=.graphrag/cache
CACHE_TTL_SECONDS=604800
CHECKPOINT_DIR=.graphrag/checkpoints
USE_HTTP_CACHE=true
USE_INGEST_CHECKPOINTS=true
HTTP_MAX_RETRIES=4
HTTP_BACKOFF_FACTOR=0.5
LOG_LEVEL=INFO
ENTITY_RESOLUTION_SIMILARITY_THRESHOLD=0.9
CLAIM_MAX_PER_CHUNK=5
COMMUNITY_REPORT_MEMBER_LIMIT=20
COMMUNITY_REPORT_CLAIM_LIMIT=12
COMMUNITY_REPORT_RELATION_LIMIT=20
